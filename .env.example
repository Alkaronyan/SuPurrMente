# Copia este fichero a .env y rellena los valores (nunca se commitea).
# En la Raspi: chmod 600 .env
#
# El entrypoint reparte estos valores en ficheros 600 por usuario dentro del
# contenedor; NO se inyectan como entorno global (aislamiento entre procesos).

# ── Whisker (Litter-Robot) ────────────────────────────────────────────────────
# NO hay usuario/contraseña aquí. Se inicia sesión una vez en el formulario web
# https://supurrmente.gonzalez.team/whisker-login (tras login Google) y se guarda un
# token revocable en /data/whisker_token.json. Si falta, el sistema avisa por email.

# ── Alertas por email (Gmail App Password, no la contraseña normal) ───────────
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
FROM_EMAIL=alfred@gonzalez.team
TO_EMAILS=joaquin@gonzalez.team

# ── Login con Google del explorador/admin (oauth2-proxy) ──────────────────────
# OAuth Client de Google Cloud (consent screen "Internal").
# Redirect URI autorizado: https://TU-DOMINIO/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# 24 bytes aleatorios en base64 = 32 caracteres exactos (oauth2-proxy exige 16/24/32):
#   python -c "import os,base64;print(base64.b64encode(os.urandom(24)).decode())"
OAUTH2_PROXY_COOKIE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OAUTH2_PROXY_REDIRECT_URL=https://supurrmente.gonzalez.team/oauth2/callback
