# Copia este fichero a .env y rellena los valores (nunca se commitea).
# En la Raspi: chmod 600 .env

# Credenciales de la cuenta Whisker (la misma que la app de la Litter-Robot)
WHISKER_USERNAME=tu@email.com
WHISKER_PASSWORD=tu_password

# Gmail App Password (no la contraseña normal) para enviar las alertas
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Remitente y destinatario(s) de las alertas. Coma-separado para varios destinos.
FROM_EMAIL=alfred@gonzalez.team
TO_EMAILS=joaquin@gonzalez.team
